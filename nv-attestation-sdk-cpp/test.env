NVAT_RIM_SERVICE_BASE_URL?=https://rim.attestation.nvidia.com
NVAT_OCSP_BASE_URL?=https://ocsp.ndis.nvidia.com
NVAT_NRAS_BASE_URL?=https://nras.attestation.nvidia.com
NVAT_C_SDK_TEST_SERVICE_KEY?=
TEST_DEVICE?=gpu
# Note: On Apple Silicon Macs (Docker Desktop x86-64 via Rosetta 2 emulation),
# high parallelism causes binary corruption under heavy concurrent I/O.
# For cross-architecture builds for docker set CMAKE_BUILD_PARALLEL_LEVEL=1
# in your environment or override this value.
CMAKE_BUILD_PARALLEL_LEVEL?=8

