# Service endpoints for the CLI test harness (tests/environment.h).
# Leave commented to use the harness's built-in default endpoints (normal/CI runs).
# To run the tests against the public production services, uncomment the lines below:
#NVAT_RIM_SERVICE_BASE_URL?=https://rim.attestation.nvidia.com
#NVAT_OCSP_BASE_URL?=https://ocsp.ndis.nvidia.com
#NVAT_NRAS_BASE_URL?=https://nras.attestation.nvidia.com
NVAT_C_SDK_TEST_SERVICE_KEY?=
TEST_DEVICE?=gpu
NVAT_CLI_TEST_LABEL?=requires-working-driver
CMAKE_BUILD_PARALLEL_LEVEL?=8
